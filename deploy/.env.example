# Heirlooms — deployment environment variables
# Copy this file to .env and fill in the values before running docker compose.
# .env is excluded from git (.gitignore). Never commit real credentials.

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------

# Username for the Heirlooms database. Can be any string.
DB_USER=heirloom

# Strong password for the database. Change this before deploying.
DB_PASSWORD=change_me_db

# -----------------------------------------------------------------------------
# MinIO (object storage)
# -----------------------------------------------------------------------------

# Root credentials for MinIO. These are used both to administer MinIO
# and by HeirloomsServer to read/write files. Change both before deploying.
MINIO_ROOT_USER=change_me_minio_user
MINIO_ROOT_PASSWORD=change_me_minio_password
