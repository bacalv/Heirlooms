# -----------------------------------------------------------------------------
local.properties
*.apk
*.aab
*.ap_
*.dex
captures/
.externalNativeBuild/
.cxx/
*.jks
*.keystore

# -----------------------------------------------------------------------------
# Kotlin
# -----------------------------------------------------------------------------
*.class
*.jar
.kotlin/
!gradle/wrapper/gradle-wrapper.jar
!**/gradle/wrapper/gradle-wrapper.jar

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
.env

# -----------------------------------------------------------------------------
# macOS
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# -----------------------------------------------------------------------------
