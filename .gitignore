# =============================================================================
# Heirlooms — root .gitignore
# Covers: Kotlin/JVM, Android, Gradle, IntelliJ IDEA, macOS
# =============================================================================

# -----------------------------------------------------------------------------
# Gradle
# -----------------------------------------------------------------------------
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
!**/gradle/wrapper/gradle-wrapper.jar

# -----------------------------------------------------------------------------
# IntelliJ IDEA
# -----------------------------------------------------------------------------
.idea/
*.iml
*.iws
*.ipr
out/

# -----------------------------------------------------------------------------
# Android
# -----------------------------------------------------------------------------
local.properties
*.apk
*.aab
*.ap_
*.dex
captures/
.externalNativeBuild/
.cxx/
*.jks
*.keystore

# -----------------------------------------------------------------------------
# Kotlin
# -----------------------------------------------------------------------------
*.class
*.jar
.kotlin/
!gradle/wrapper/gradle-wrapper.jar
!**/gradle/wrapper/gradle-wrapper.jar

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
.env

# -----------------------------------------------------------------------------
# macOS
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# -----------------------------------------------------------------------------
# Test reports
# -----------------------------------------------------------------------------
HeirloomsTest/build/reports/

# -----------------------------------------------------------------------------
# Device farm — secrets and ephemeral run files
# -----------------------------------------------------------------------------
# Device serial mapping — contains hardware identifiers, never commit
scripts/test-farm/.env
# Per-run test account credentials — discarded after each run
scripts/test-farm/.farm-env
# Test run output (JUnit XML, screenshots, logcat dumps)
test-results/farm/
