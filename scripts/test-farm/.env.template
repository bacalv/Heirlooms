# Device farm serial numbers / TCP addresses.
# Copy this file to .env and fill in the actual values.
# .env is gitignored — never commit it.
#
# Usage:
#   cp scripts/test-farm/.env.template scripts/test-farm/.env
#   # edit .env with the ADB serials shown by `adb devices`
#
# ADB serial format examples:
#   USB:    RFCR804WXYZ  (printed on device or from `adb devices`)
#   Wi-Fi:  192.168.1.42:5555  (after `adb tcpip 5555 && adb connect <ip>:5555`)

# Device A — Minimum API (Android 9, API 28)
FARM_DEVICE_MINAPI=

# Device B — Current mainstream (Android 14, API 34)
FARM_DEVICE_CURRENT=

# Device C — Bleeding-edge / regression (Android 15, API 35)
FARM_DEVICE_LATEST=
