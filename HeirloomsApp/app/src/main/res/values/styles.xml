<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Translucent" parent="android:Theme.Translucent.NoTitleBar" />

    <!-- Base Heirlooms theme: parchment background, no action bar. Used by MainActivity. -->
    <style name="Theme.Heirlooms" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@color/parchment</item>
        <item name="android:statusBarColor">@color/parchment</item>
        <item name="android:navigationBarColor">@color/parchment</item>
    </style>

    <!-- Receive screen variant. Used by ShareActivity. -->
    <style name="Theme.Heirlooms.Share" parent="Theme.Heirlooms" />
</resources>
