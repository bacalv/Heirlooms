<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="@android:color/background_light">

    <TextView
        android:id="@+id/labelTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/settings_title"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/labelApiKey"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/settings_api_key_label"
        android:textSize="14sp"
        android:textColor="@android:color/black"
        android:paddingTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/labelTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <EditText
        android:id="@+id/editApiKey"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="@string/settings_api_key_hint"
        android:inputType="textPassword"
        android:singleLine="true"
        android:textSize="14sp"
        android:paddingTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/labelApiKey"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <CheckBox
        android:id="@+id/checkWifiOnly"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/settings_wifi_only"
        android:textSize="14sp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/editApiKey"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/btnSave"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/settings_save"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/checkWifiOnly"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
