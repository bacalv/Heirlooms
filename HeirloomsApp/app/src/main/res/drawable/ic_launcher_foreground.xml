<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon foreground — parchment olive branch on transparent ground.
  Canvas: 108×108dp. Design is centred within the 18–90dp safe zone via
  the outer group translate(24,24), placing the 60-unit composition at
  24–84dp. Ellipses converted to closed arc paths; rotations applied via
  wrapping <group> elements so transform-origin is preserved exactly.
  Hex colours: #F2EEDF = parchment. No CSS vars — standalone drawables
  resolve outside the page CSS context.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <group
        android:translateX="24"
        android:translateY="24">

        <!-- Branch — stroke only, no fill -->
        <path
            android:fillColor="#00000000"
            android:strokeColor="#F2EEDF"
            android:strokeWidth="2.5"
            android:strokeLineCap="round"
            android:pathData="M 30,48 C 32,38 28,22 30,14" />

        <!-- Leaf pair 1 — bottom/largest -->
        <group android:rotation="18" android:pivotX="27" android:pivotY="39">
            <path android:fillColor="#F2EEDF"
                android:pathData="M 17.5,40 A 4.5,1.3 0 1 0 26.5,40 A 4.5,1.3 0 1 0 17.5,40 Z" />
        </group>
        <group android:rotation="-18" android:pivotX="33" android:pivotY="39">
            <path android:fillColor="#F2EEDF"
                android:pathData="M 33.5,40 A 4.5,1.3 0 1 0 42.5,40 A 4.5,1.3 0 1 0 33.5,40 Z" />
        </group>

        <!-- Leaf pair 2 — middle -->
        <group android:rotation="22" android:pivotX="26" android:pivotY="31">
            <path android:fillColor="#F2EEDF"
                android:pathData="M 18,32 A 4,1.2 0 1 0 26,32 A 4,1.2 0 1 0 18,32 Z" />
        </group>
        <group android:rotation="-22" android:pivotX="34" android:pivotY="31">
            <path android:fillColor="#F2EEDF"
                android:pathData="M 34,32 A 4,1.2 0 1 0 42,32 A 4,1.2 0 1 0 34,32 Z" />
        </group>

        <!-- Leaf pair 3 — top/smallest -->
        <group android:rotation="26" android:pivotX="27" android:pivotY="23">
            <path android:fillColor="#F2EEDF"
                android:pathData="M 20.8,24 A 3.2,1 0 1 0 27.2,24 A 3.2,1 0 1 0 20.8,24 Z" />
        </group>
        <group android:rotation="-26" android:pivotX="33" android:pivotY="23">
            <path android:fillColor="#F2EEDF"
                android:pathData="M 32.8,24 A 3.2,1 0 1 0 39.2,24 A 3.2,1 0 1 0 32.8,24 Z" />
        </group>

        <!-- Olive at apex -->
        <path android:fillColor="#F2EEDF"
            android:pathData="M 28.1,13 A 1.9,2.6 0 1 0 31.9,13 A 1.9,2.6 0 1 0 28.1,13 Z" />

    </group>

</vector>
