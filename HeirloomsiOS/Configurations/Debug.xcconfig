// Debug.xcconfig — HeirloomsApp Debug build configuration
//
// Apply this file to the HeirloomsApp target's Debug configuration in Xcode:
//   Project navigator → HeirloomsApp.xcodeproj → PROJECT (not target) →
//   Info → Configurations → Debug → click the disclosure triangle next to
//   HeirloomsApp → select "Debug" (this file).
//
// What this file sets:
//
//   INFOPLIST_FILE
//     Points the build system at the committed Info.plist.  This is the
//     primary purpose of this xcconfig (SEC-016 acceptance criterion 4).
//
//   INFOPLIST_PREPROCESSOR_DEFINITIONS
//     Passes DEBUG=1 into Xcode's plist pre-processor so the #if DEBUG /
//     #endif blocks inside Info.plist are evaluated and the localhost /
//     192.168 ATS exceptions are included only in debug builds.
//
//   MARKETING_VERSION / CURRENT_PROJECT_VERSION
//     Defaults; override in the Xcode target's Build Settings if needed.
//
//   PRODUCT_BUNDLE_IDENTIFIER
//     Uses the .dev suffix for debug/development installs so the build can
//     co-exist with a production install on the same device.

INFOPLIST_FILE = HeirloomsApp/Info.plist

// Activate the #if DEBUG block inside Info.plist (localhost ATS exception).
INFOPLIST_PREPROCESSOR_DEFINITIONS = DEBUG=1

MARKETING_VERSION = 1.0
CURRENT_PROJECT_VERSION = 1

PRODUCT_BUNDLE_IDENTIFIER = digital.heirlooms.ios.dev

// Swift active compilation condition — enables #if DEBUG in Swift source too.
SWIFT_ACTIVE_COMPILATION_CONDITIONS = DEBUG
